PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://admin:secret@localhost:27017/crm?authSource=admin

# Clerk — from your Clerk dashboard (API Keys). Must match the frontend instance.
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# From the Clerk dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# App-owned deployer wallet. Generate a fresh one (npm run create-wallet) and
# keep the private key only in your local .env — never commit a real key.
INTERNAL_WALLET_ADDRESS=0xYourWalletAddress
INTERNAL_WALLET_PRIVATE=0xYourWalletPrivateKey

# Blockchain RPC + chain name. Use your own provider key (e.g. Alchemy/Infura).
BC_HTTP=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BC_WSS=wss://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BC_NAME=base-sepolia

# Redis for the BullMQ deploy queue. When set, contract deploys run async.
REDIS_URL=redis://localhost:6379

# Shared secret for signing Centrifugo connection tokens. Must match
# CENTRIFUGO_TOKEN_HMAC_SECRET in the root .env / Centrifugo container.
CENTRIFUGO_TOKEN_HMAC_SECRET=secret

# Centrifugo HTTP API for server-side publishing into channels. CENTRIFUGO_API_KEY
# must match CENTRIFUGO_API_KEY in the root .env / Centrifugo container.
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=secret
