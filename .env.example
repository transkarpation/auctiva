# MongoDB credentials
MONGO_USERNAME=admin
MONGO_PASSWORD=secret
MONGO_DATABASE=crm

# Mongo Express UI basic-auth login (http://localhost:8081)
ME_USERNAME=admin
ME_PASSWORD=secret

# Centrifugo — secrets shared with the backend/admin UI. Override in production.
CENTRIFUGO_ADMIN_PASSWORD=secret
CENTRIFUGO_ADMIN_SECRET=secret
CENTRIFUGO_API_KEY=secret
# Signs client connection tokens; the backend must use the same value.
CENTRIFUGO_TOKEN_HMAC_SECRET=secret

# Browser origins allowed to open Centrifugo WebSocket connections (space-separated).
# Set this to your deployed frontend origin in production.
CENTRIFUGO_ALLOWED_ORIGINS=http://localhost:5173
