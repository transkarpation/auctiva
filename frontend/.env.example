# Clerk frontend SDK key (must match the backend's Clerk instance).
VITE_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API base URL.
VITE_API_URL=http://localhost:4000

# Centrifugo websocket endpoint.
VITE_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket

# Base Sepolia RPC for wallet/contract reads (use your own provider key).
VITE_BASE_SEPOLIA_HTTP=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optional: enables WalletConnect mobile wallets (https://cloud.reown.com).
VITE_WALLETCONNECT_PROJECT_ID=
